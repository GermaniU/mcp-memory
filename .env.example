# ─── Embeddings ───────────────────────────────────────────────────────────
# Modelo y dimensión. EMBEDDING_DIM debe coincidir EXACTO con el modelo:
#   bge-m3              → 1024
#   mxbai-embed-large   → 1024
#   nomic-embed-text    →  768
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# ─── Ollama ───────────────────────────────────────────────────────────────
# Default: tu Ollama local (recomendado — Ollama Cloud NO expone embeddings).
# Pre-requisito: ollama pull bge-m3
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=
#
# Alternativa — Ollama remoto (tu servidor):
# OLLAMA_URL=https://ollama.tu-dominio.com
# OLLAMA_API_KEY=opcional_si_pones_proxy_con_auth

# ─── Qdrant ───────────────────────────────────────────────────────────────
# El default apunta al servicio "qdrant" del docker-compose (Qdrant bundled).
# Para usar tu PROPIO Qdrant (ya tienes uno corriendo): exporta QDRANT_URL y
# levanta solo el server con `docker compose up mcp-memory` (no arranca el
# Qdrant bundled). Ej. con Qdrant en el host:
#   QDRANT_URL=http://host.docker.internal:6333
# O con un Qdrant remoto:
#   QDRANT_URL=https://qdrant.tu-dominio.com
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=mcp_memory

# ─── MCP server ───────────────────────────────────────────────────────────
MCP_PORT=8765
DEFAULT_NAMESPACE=default
